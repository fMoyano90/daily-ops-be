DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dailyops
CORS_ORIGINS=["http://localhost:3000"]
APP_NAME="DailyOps API"
APP_VERSION="0.2.0"

JIRA_ENCRYPTION_KEY=your-32-byte-hex-key-here
JIRA_SYNC_ENABLED=True
JIRA_SYNC_INTERVAL_MINUTES=30

AUTO_CLOSE_ENABLED=True
AUTO_CLOSE_HOUR=0
AUTO_CLOSE_MINUTE=1

JWT_SECRET_KEY=generate-with-secrets-token-urlsafe-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

FOUNDER_EMAIL=f.moyano90@gmail.com
FOUNDER_PASSWORD=your-secure-password
FOUNDER_DISPLAY_NAME=Felipe Moyano

# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=f.moyano90@gmail.com
